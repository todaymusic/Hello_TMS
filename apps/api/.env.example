# ===== hellotms API 환경변수 (Railway api 서비스에 입력) =====
# --- 필수 ---
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB   # Railway Postgres (플러그인 추가 후 참조)
JWT_SECRET=change-me-to-a-long-random-string       # 로그인 토큰 서명 (반드시 새 값으로!)

# --- AI 기능(업무설명 doc·데일리 평가) 쓰면 필수 ---
ANTHROPIC_API_KEY=sk-ant-...

# --- 선택 ---
# FRONTEND_ORIGIN=https://<web>.up.railway.app     # web이 *.up.railway.app이면 불필요
# PORT=4000                                        # Railway가 자동 주입

# --- (남긴 4개 페이지엔 불필요) 미팅/푸시 기능용 ---
# VAPID_PUBLIC=  VAPID_PRIVATE=  VAPID_SUBJECT=
# GOOGLE_SERVICE_ACCOUNT_JSON=  GCS_BUCKET=  MEETINGS_DRIVE_FOLDER_ID=  STT_LOCATION=
